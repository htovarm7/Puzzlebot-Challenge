<?xml version="1.0" encoding="UTF-8" ?>
<!--
    FastDDS unicast discovery — Puzzlebot multi-machine via Tailscale.

    Reemplaza TU_LAPTOP_IP con tu IP de Tailscale:
      tailscale ip -4

    IP del Jetson es siempre: 100.73.89.116
    Ver docs/MULTIPROCESSING.md para instrucciones completas.

    IMPORTANTE: este archivo debe estar en AMBAS máquinas con los mismos IPs.
    En el Jetson: ~/fastdds_puzzlebot.xml
    En la laptop: ~/fastdds_puzzlebot.xml
-->
<profiles xmlns="http://www.eprosima.com/XMLSchemas/fastRTPS_Profiles">
    <participant profile_name="unicast_profile" is_default_profile="true">
        <rtps>
            <builtin>
                <initialPeersList>
                    <!-- Localhost: descubrimiento entre nodos en la misma máquina -->
                    <locator>
                        <udpv4>
                            <address>127.0.0.1</address>
                        </udpv4>
                    </locator>
                    <!-- IP del Jetson en Tailscale (fija) -->
                    <locator>
                        <udpv4>
                            <address>100.73.89.116</address>
                        </udpv4>
                    </locator>
                    <!-- IP de la laptop en Tailscale — reemplaza con: tailscale ip -4 -->
                    <locator>
                        <udpv4>
                            <address>100.90.40.98</address>
                        </udpv4>
                    </locator>
                </initialPeersList>
            </builtin>
        </rtps>
    </participant>
</profiles>
